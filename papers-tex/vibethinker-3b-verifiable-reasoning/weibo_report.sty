% weibo_report.sty - Weibo Technical Report Style
% Built on top of neurips_2026.sty
%
% Usage:
%   \usepackage[main, final]{neurips_2026}
%   \usepackage{weibo_report}
%
% Commands:
%   \weibologo{logo.pdf}
%   \weiboauthors{Author One$^{1,*}$, Author Two$^{2}$}
%   \weiboaffils{$^1$Weibo, $^2$University}
%   \weibonotes{$^*$Corresponding author}
%   \weibodate{April 29, 2026}
%   \weibocorrespondence{Author at email@weibo.com}
%   \weiboprojectpage{https://github.com/weibo/project}
%   \weibogithub{\url{https://github.com/weibo/project}}
%   \weibohuggingface{\url{https://huggingface.co/weibo/project}}

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{weibo_report}[2026/04/29 Weibo Technical Report Style]

% Required packages
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins,breakable}
\RequirePackage{fancyhdr}
\RequirePackage{afterpage}

% ===== Header / Footer =====
\let\@weiboheader\@empty
\newcommand{\weiboheader}[1]{\def\@weiboheader{#1}}

\fancypagestyle{weibopages}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0.4pt}%
  \renewcommand{\headrule}{\hrule width\textwidth height\headrulewidth\vskip-\headrulewidth}%
  \fancyhead[C]{\fontsize{9pt}{11pt}\selectfont\@weiboheader}%
  \fancyfoot[R]{\thepage}%
}
\fancypagestyle{weibofirstpage}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
  \fancyfoot[L]{%
    \ifx\@weibonotes\@empty\else
      \parbox{\textwidth}{%
        \vspace*{-4pt}%
        \hrule width 12pc height 0.4pt\relax
        \vskip 6pt
        \footnotesize\@weibonotes
      }%
    \fi
  }%
}
\AtBeginDocument{%
  \pagestyle{weibopages}%
  \raggedbottom
}

% ===== Override page geometry =====
% Single geometry for all pages; first page adjusts via negative vspace
\AtBeginDocument{%
  \newgeometry{%
    textheight=9.35in,
    textwidth=6.5in,
    top=0.7in,
    headheight=14pt,
    headsep=10pt,
    footskip=24pt
  }%
  \setlength{\headwidth}{\textwidth}%
}

% ===== Weibo Brand Colors =====
\definecolor{weibored}{HTML}{E6162D}
\definecolor{weiboorange}{HTML}{FF8200}
\definecolor{weibogray}{HTML}{999999}
\definecolor{weibodarkred}{HTML}{B8122A}
\definecolor{weiboborder}{HTML}{D4364A}
\definecolor{weibolightbg}{HTML}{FFF8F8}

% ===== Metadata Commands =====
\let\@weibologo\@empty
\newcommand{\weibologo}[1]{\def\@weibologo{#1}}

\let\@weiboauthors\@empty
\newcommand{\weiboauthors}[1]{\def\@weiboauthors{#1}}

\let\@weiboaffils\@empty
\newcommand{\weiboaffils}[1]{\def\@weiboaffils{#1}}

\let\@weibonotes\@empty
\newcommand{\weibonotes}[1]{\def\@weibonotes{#1}}

% --- Ordered metadata accumulator ---
\def\@weibometalist{}
\newcommand{\@weibometaappend}[1]{%
  \g@addto@macro\@weibometalist{#1}%
}

\newcommand{\weibodate}[1]{%
  \@weibometaappend{{\small\textbf{\color{weibodarkred}Date:}~#1\par}}%
}
\newcommand{\weibocorrespondence}[1]{%
  \@weibometaappend{{\small\textbf{\color{weibodarkred}Correspondence:}~#1\par}}%
}
\newcommand{\weiboprojectpage}[1]{%
  \@weibometaappend{{\small\textbf{\color{weibodarkred}Project Page:}~{\color{weibodarkred}\url{#1}}\par}}%
}
\newcommand{\weibogithub}[1]{%
  \@weibometaappend{{\small\textbf{\color{weibodarkred}GitHub:}~{\color{weibodarkred}#1}\par}}%
}
\newcommand{\weibohuggingface}[1]{%
  \@weibometaappend{{\small\textbf{\color{weibodarkred}Hugging Face:}~{\color{weibodarkred}#1}\par}}%
}

% ===== Override \maketitle =====
\renewcommand{\maketitle}{%
  \par
  \thispagestyle{weibofirstpage}%
  \vspace*{-0.45in}% Pull first page up so logo starts near top
  \vbox{%
    \hsize\textwidth
    \linewidth\hsize
    \vskip 0.02in
    % --- Logo (flush left) ---
    \ifx\@weibologo\@empty\else
      \noindent\includegraphics[height=0.75cm]{logo.pdf}%
      \par\vskip 0.02in
    \fi
    % --- Colored top rule ---
    {\color{black}\hrule height 1\p@}%
    \vskip 0.25in
    \vskip -\parskip
    % --- Title ---
    \begin{center}%
      {\LARGE\bfseries \@title\par}%
    \end{center}%
    \vskip 0.18in
    % --- Authors with superscripts ---
    \ifx\@weiboauthors\@empty\else
      \begin{center}%
        {\normalsize \@weiboauthors\par}%
      \end{center}%
      \vskip -0.03in
    \fi
    % --- Affiliations ---
    \ifx\@weiboaffils\@empty\else
      {\centering
        {\small \@weiboaffils\par}%
      }%
      \vskip 0.08in
    \fi
    \vskip 0.01in
  }%
  \let\maketitle\relax
  \let\thanks\relax
}

% ===== Override abstract with rounded colored box =====
\renewenvironment{abstract}{%
  \begin{tcolorbox}[
    enhanced,
    colback=weibolightbg,
    colframe=weiboborder,
    arc=10pt,
    boxrule=0.8pt,
    left=12pt, right=12pt,
    top=8pt, bottom=8pt,
    breakable,
    drop shadow={weibored!8},
  ]%
  \centerline{\large\bfseries\color{weibored} Abstract}%
  \vspace{0.4ex}%
}{%
  % --- Metadata block: only show if at least one field was declared ---
  \ifx\@weibometalist\@empty\else
    \par\vskip 1ex
    {\color{weibored!25}\hrule height 0.4pt}%
    \vskip 1.2ex
    \@weibometalist
  \fi
  \end{tcolorbox}%
  \vskip 0.5ex%
}

% ===== Enlarge body & section fonts (10pt→11pt scale) =====
% normalsize: 10pt/11pt → 11pt/13pt
\renewcommand{\normalsize}{%
  \@setfontsize\normalsize{10pt}{12pt}%
  \abovedisplayskip      6\p@ \@plus 2\p@ \@minus 4\p@
  \abovedisplayshortskip \z@ \@plus 3\p@
  \belowdisplayskip      \abovedisplayskip
  \belowdisplayshortskip 3\p@ \@plus 3\p@ \@minus 3\p@
}
\normalsize
% small: 10pt → 9pt
\renewcommand{\small}{%
  \@setfontsize\small{9pt}{11pt}%
  \abovedisplayskip      5\p@ \@plus 1.5\p@ \@minus 3\p@
  \abovedisplayshortskip \z@  \@plus 2\p@
  \belowdisplayskip      \abovedisplayskip
  \belowdisplayshortskip 3\p@ \@plus 2\p@   \@minus 2\p@
}
% section headings: 12pt→13pt, subsection 10pt→11pt (auto via normalsize)
\renewcommand{\large}{\@setfontsize\large{13pt}{15.5pt}}
\renewcommand{\Large}{\@setfontsize\Large{15pt}{18pt}}

% ===== Tighter itemize/enumerate indentation =====
\RequirePackage{enumitem}
\setlist[itemize]{leftmargin=1.7em, itemsep=2pt, parsep=0pt, topsep=2pt}
\setlist[enumerate]{leftmargin=1.7em, itemsep=2pt, parsep=0pt, topsep=2pt}

% ===== Suppress NeurIPS conference notice =====
\renewcommand{\@notice}{}

\endinput
